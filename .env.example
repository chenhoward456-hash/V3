# Supabase 設定
# 請將以下內容複製到 .env.local 檔案中

# 1. Project URL（從 Supabase API 頁面複製）
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# 2. Anon Public Key（從 Supabase API 頁面複製）
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# 3. Service Role Key（從 Supabase API 頁面複製，僅用於後端 API）
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# 4. 後台密碼（請設定一個強密碼，至少 12 字元，包含大小寫和數字）
ADMIN_PASSWORD=your-secure-admin-password-here

# 5. 教練 PIN 碼（用於客戶端教練模式，建議 6-8 位數字）
COACH_PIN=your-coach-pin-here

# 6. 綠界 ECPay 金流（電子書購買）
# 測試環境：到 https://vendor-stage.ecpay.com.tw 申請
# 正式環境：到綠界後台取得
# 必填，不設定則金流功能無法使用
ECPAY_MERCHANT_ID=your-merchant-id
ECPAY_HASH_KEY=your-hash-key
ECPAY_HASH_IV=your-hash-iv

# 7. ECPay 正式環境開關（設為 true 啟用正式付款 URL）
# ECPAY_PRODUCTION=true

# 8. Resend 信件服務（付款成功自動寄下載連結）
# 免費方案：每月 3000 封，到 https://resend.com 註冊
RESEND_API_KEY=re_xxxxxxxxxxxx
# 自訂寄件人（需先在 Resend 驗證 domain）
# 未設定時使用 Resend 預設的 onboarding@resend.dev
# RESEND_FROM_EMAIL=Howard Protocol <noreply@howardprotocol.com>

# 9. 網站 URL（用於信件中的連結）
NEXT_PUBLIC_SITE_URL=https://howardprotocol.com

# 10. Cron Job 驗證密鑰（Vercel Cron 自動帶入，防止未授權觸發每週分析）
# 到 Vercel Dashboard → Settings → Environment Variables 設定
CRON_SECRET=your-cron-secret-here

# 11. Anthropic API Key（AI 教練建議功能）
# 到 https://console.anthropic.com 申請，使用 Haiku 模型（便宜快速）
# 不設定則 AI 教練功能不可用，其他功能不受影響
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxx

# 12. LINE Bot（學員在 LINE 裡記錄飲食/體重）
# 到 LINE Developers Console 申請 Messaging API channel
# LINE_CHANNEL_ACCESS_TOKEN=your-channel-access-token
# LINE_CHANNEL_SECRET=your-channel-secret

# 使用方式：
# 1. 將此檔案重新命名為 .env.local
# 2. 替換上面所有 your-xxx-here 的值
# 3. 儲存檔案後重新啟動服務器
# 4. 注意：請勿將 .env.local 提交到版本控制
